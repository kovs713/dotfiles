      "class<tor-browser>": "’Ź▒",
      "class<firefox-developer-edition>": "­¤”Ŗ",
      "class<kitty|konsole|kitty-dropterm|com.mitchellh.ghostty|org.wezfurlong.wezterm|org.omarchy.terminal>": "’Ź»",
      "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "’Ź░",
      "class<eu.betterbird.Betterbird>": "’Ź░",
      "title<.*gmail.*>": "¾░Ŗ½",
      "class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop|ayugram|Ayugram>": "ŅłŚ",
      "class<discord|[Ww]ebcord|Vesktop>": "’ć┐",
      "title<.*whatsapp.*>": "’ł▓",
      "title<.*zapzap.*>": "’ł▓",
      "title<.*messenger.*>": "’ē¤",
      "title<.*facebook.*>": "’éÜ ",
      "title<.*reddit.*>": "’Ŗü",
      "title<.*ChatGPT.*>": "¾░Ü®",
      "class<.*ChatGPT.*>": "¾░Ü®",
      "title<.*deepseek.*>": "¾░Ü®",
      "title<.*qwen.*>": "¾░Ü®",
      "class<subl>": "¾░ģ│",
      "class<slack>": "’åś",
      "class<mpv>": "’Ź«",
      "class<celluloid|Zoom>": "’ĆĮ",
      "class<Cider>": "¾░Äå ",
      "title<.*Picture-in-Picture.*>": "’ö¼",
      "title<.*youtube.*>": "’ģ¬",
      "class<vlc>": "¾░Ģ╝",
      "title<.*cmus.*>": "’Ćü",
      "class<[Ss]potify>": "’å╝",
      "class<virt-macodeger>": "ŅŁ╗",
      "class<.virt-manager-wrapped>": "ŅŁ╗",
      "class<virtualbox manager>": "­¤ÆĮ",
      "title<virtualbox>": "­¤ÆĮ",
      "class<remmina>": "­¤¢ź’ĖÅ",
      "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "¾░©×",
      "class<dev.zed.Zed>": "¾░Ąü",
      "class<codeblocks>": "¾░ģ®",
      "title<.*github.*>": "’äō",
      "class<mousepad>": "’ģ£",
      "class<libreoffice-writer>": "ŅÜź",
      "class<libreoffice-startcenter>": " ¾░Åå",
      "class<libreoffice-calc>": "’Ź╗",
      "title<.*nvim ~.*>": "’Ź»",
      "class<org.gnome.Nautilus>": "¾░Żå",
      "title<.*vim.*>": "Ņ¤ģ",
      "title<.*figma.*>": "ŅĮć",
      "title<.*jira.*>": "ŅØ£",
      "class<jetbrains-idea>": "Ņ×Ą",
      "title<*.VSCode.*>": "¾░©×",
      "class<.*code.*>": "¾░©×",
      "class<obs|com.obsproject.Studio>": "Ņ«¦",
      "class<polkit-gnome-authentication-agent-1>": "¾░Æā",
      "class<nwg-look>": "ŅŁÆ",
      "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "¾▒Ī½",
      "class<steam>": "’åČ",
      "class<thunar|nemo>": "¾░Ø░",
      "class<Gparted>": "’āć",
      "class<gimp>": "’īĖ",
      "class<emulator>": "­¤ō▒",
      "class<android-studio>": "’ģ╗",
      "class<org.pipewire.Helvum>": "¾░ōā",
      "class<localsend>": "’ćĀ",
      "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "¾░╣ø"
    }
  },
  "custom/omarchy-theme": {
    "exec": "omarchy-theme-current",
    "interval": 5,
    "format": "{}"
  },
  "custom/omarchy-theme-set": {
    "on-click": "omarchy-theme-set Harbordark",
    "tooltip-format": "Back to your setted Themes",
    "interval": 5,
    "format": "¾░öÄ"
  },
  "custom/omarchy": {
    "format": "<span font='omarchy'>\ue900</span>",
    "on-click": "omarchy-menu",
    "on-click-right": "xdg-terminal-exec",
    "tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
  },
  "custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "¾░Ź¼",
      "transcribing": "¾░ö¤"
    },
    "tooltip": true,
    "on-click-right": "omarchy-voxtype-config",
    "on-click": "omarchy-voxtype-model"
  },
  "custom/idle-indicator": {
    "on-click": "omarchy-toggle-idle",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
    "signal": 9,
    "return-type": "json"
  },
  "custom/notification-silencing-indicator": {
    "on-click": "omarchy-toggle-notification-silencing",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "signal": 10,
    "return-type": "json"
  },
  "custom/update": {
    "format": "’ĆĪ",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "tooltip-format": "Omarchy update available",
    "signal": 7,
    "interval": 21600
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "¾░øŖ",
      "deactivated": "¾░Š¬"
    }
  },
  "cpu": {
    "interval": 2,
    "format": "¾░Źø {usage}%",
    "on-click": "omarchy-launch-or-focus-tui btop"
  },
  "memory": {
    "interval": 2,
    "format": "Ņē” {percentage}%",
    "on-click": "omarchy-launch-or-focus-tui btop"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "tooltip-format": "{percent}%",
    "format-icons": [
      "­¤īæ",
      "­¤īś",
      "­¤īŚ",
      "­¤ī¢",
      "­¤īĢ"
    ]
  },
  "network": {
    "format-icons": [
      "¾░ż»",
      "¾░ż¤",
      "¾░żó",
      "¾░żź",
      "¾░ż©"
    ],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "¾░łĆ",
    "format-disconnected": "¾░ż«",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nŌćŻ{bandwidthDownBytes}  ŌćĪ{bandwidthUpBytes}",
    "tooltip-format-ethernet": "ŌćŻ{bandwidthDownBytes}  ŌćĪ{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "omarchy-launch-wifi"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{capacity}% {icon}",
    "format-charging": "{capacity}% {icon}",
    "format-plugged": "’ć”",
    "format-icons": {
      "charging": [
        "¾░ó£",
        "¾░éå",
        "¾░éć",
        "¾░éł",
        "¾░óØ",
        "¾░éē",
        "¾░ó×",
        "¾░éŖ",
        "¾░éŗ",
        "¾░éģ"
      ],
      "default": [
        "¾░ü║",
        "¾░ü╗",
        "¾░ü╝",
        "¾░üĮ",
        "¾░üŠ",
        "¾░ü┐",
        "¾░éĆ",
        "¾░éü",
        "¾░éé",
        "¾░ü╣"
      ]
    },
    "format-full": "¾░éģ {capacity}%",
    "tooltip-format-discharging": "{timeTo}",
    "tooltip-format-charging": "{timeTo}",
    "interval": 5,
    "on-click": "omarchy-menu power",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "bluetooth": {
    "format": "’Ŗö",
    "format-disabled": "¾░é▓",
    "format-connected": "¾░é▒",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "omarchy-launch-bluetooth"
  },
  "pulseaudio#input": {
    "format-source": "’ä░",
    "format-source-muted": "’ä▒ ",
    "format": "{format_source}",
    "tooltip-format": "{format_source} {source_volume}%",
    "scroll-step": 1,
    "smooth-scrolling-threshold": 1,
    "max-volume": 100,
    "on-click": "omarchy-launch-or-focus-tui wiremix",
    "on-click-right": "pamixer -t",
    "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +1%",
    "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -1%"
  },
  "pulseaudio#output": {
    "format": "{icon}",
    "tooltip-format": "{icon}  {volume}%",
    "format-muted": "’Ć” off",
    "format-icons": {
      "default": [
        "’Ćź"
      ]
    },
    "max-volume": 100,
    "scroll-step": 2,
    "smooth-scrolling-threshold": 1,
    "on-click": "omarchy-launch-or-focus-tui wiremix",
    "on-click-right": "pamixer -t"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "¾░ōģ",
      "performance": "¾░ōģ",
      "balanced": "¾░Šģ",
      "power-saver": "¾░Šå"
    }
  },
  "mpris": {
    "format": "¾░ŗÄ {artist}-{title}",
    "format-paused": "<i><span color='grey'>{status_icon} {artist}</span></i>",
    "max-length": 30,
    "player-icons": {
      "default": "ŌÅĖ",
      "mpv": "­¤ÄĄ"
    },
    "status-icons": {
      "paused": "¾░ŗÉ"
    },
    "ignored-players": [
      "chromium",
      "brave"
    ]
  },
  "custom/screenrecording-indicator": {
    "on-click": "omarchy-cmd-screenrecord",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/screen-recording.sh",
    "signal": 8,
    "return-type": "json"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 5,
    "show-passive-items": true
  }
}
