{
  "exclusive": true,
  "reload_style_on_change": true,
  "position": "bottom",
  "spacing": 0,
  "height": 40,
  "margin-top": 0,
  "modules-left": [
    "group/left1",
    "group/left2",
    "mpris"
  ],
  "group/left1": {
    "orientation": "inherit",
    "modules": [
      "backlight",
      "network",
      "bluetooth",
      "pulseaudio#output",
      "pulseaudio#input",
      "power-profiles-daemon",
      "memory",
      "cpu",
      "battery"
    ]
  },
  "group/left2": {
    "orientation": "inherit",
    "modules": [
      "tray"
    ]
  },
  "modules-center": [
    "clock",
    "hyprland/language",
    "custom/screenrecording-indicator"
  ],
  "clock": {
    "format": " ’ĆŚ {:%H:%M %d/%m/%Y} ",
    "format-alt": " {:L%d %B W%V %Y} ",
    "tooltip-format": "<span>{calendar}</span>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-click-right": "mode",
      "format": {
        "month": "<span color='#ffead3'><b>{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b>{}</b></span>"
      },
    },
    "on-click-right": "omarchy-launch-floating-terminal-with-presentation omarchy-tz-select"
  },
  "hyprland/language": {
    "format": "| {} | ",
    "format-en": "EN",
    "format-ru": "RU",
    "tooltip": false
  },
  "modules-right": [
    "hyprland/workspaces"
  ],
  "hyprland/workspaces": {
    "persistent-workspaces": {
      "*": [
        1,
        2,
        3,
        4,
        5
      ]
    },
    "on-click": "activate",
    "format": "{icon} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "’üÖ",
    "window-rewrite": {
      "class<.*imv*.>": "’ōź",
      "class<.*bambustudio*.>": "¾░É½",
      "class<.*bitwarden*.>": "Ņ┤ź",
      "class<.*handbrake*.>": "¾░ł½",
      "class<.*stremio*.>": "¾▒¢Å",
      "title<.*waydroid*.>": "Ņ£Ä",
      "title<.*amazon.*>": "’ē░",
      "class<.*grayjay*.>": "¾▒Śå",
      "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "ŅØģ",
      "class<zen>": "¾░░Ę",
      "class<waterfox|waterfox-bin>": "Ņ║ō",
