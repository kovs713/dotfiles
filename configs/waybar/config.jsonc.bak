{
	"exclusive": true,
	"reload_style_on_change": true,
	"position": "top",
	"spacing": 0,
	"height": 15,
	"margin-top": 0,
	"modules-left": [
		"group/left1",
		"group/left2",
		"group/left3",
		"group/left4"
	],
	"group/left1": {
		"orientation": "inherit",
		"modules": [
			"custom/omarchy",
			"clock",
			"custom/idle-indicator",
			"custom/notification-silencing-indicator",
			"custom/voxtype",
			"idle_inhibitor",
			"custom/screenrecording-indicator",
			"custom/updatespacman",
			"custom/update"
		]
	},
	"group/left2": {
		"orientation": "inherit",
		"modules": [
			"tray"
		]
	},
	"group/left3": {
		"orientation": "inherit",
		"modules": [
			"custom/omarchy-theme",
			"custom/omarchy-theme-set"
		]
	},
	"modules-center": [
		"hyprland/workspaces"
	],
	"modules-right": [
		"group/right2",
		"group/right1"
	],
	"group/right1": {
		"orientation": "inherit",
		"modules": [
			"backlight",
			"network",
			"bluetooth",
			"pulseaudio#output",
			"pulseaudio#input",
			"power-profiles-daemon",
			"memory",
			"cpu",
			"battery"
		]
	},
	"group/right2": {
		"orientation": "inherit",
		"modules": [
			"mpris"
		]
	},
	"custom/omarchy-theme": {
		"exec": "omarchy-theme-current",
		"interval": 5,
		"format": "{}"
	},
	"custom/omarchy-theme-set": {
		"on-click": "omarchy-theme-set Harbordark",
		"tooltip-format": "Back to your setted Themes",
		"interval": 5,
		"format": "≤░ΦΟ"
	},
	"hyprland/workspaces": {
		"persistent-workspaces": {
			"*": [
				1,
				2,
				3,
				4,
				5,
				6
			]
		},
		"on-click": "activate",
		"format": "{icon} {windows}",
		"format-window-separator": " ",
		"window-rewrite-default": "ΎΒβ",
		"window-rewrite": {
			"class<.*imv*.>": "ΎΥξ",
			"class<.*bambustudio*.>": "≤░Ρτ",
			"class<.*bitwarden*.>": "Ό┤ξ",
			"class<.*handbrake*.>": "≤░Ιτ",
			"class<.*stremio*.>": "≤▒ΨΠ",
			"title<.*waydroid*.>": "ΌεΟ",
			"class<.*grayjay*.>": "≤▒ΩΗ",
			"title<.*amazon.*>": "ΎΚ░",
			"class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "ΌζΖ",
			"class<zen>": "≤░░╖",
			"class<waterfox|waterfox-bin>": "Ό║Υ",
			"class<microsoft-edge>": "ΎΛΓ",
			"class<Chromium|Thorium|[Cc]hrome>": "ΎΚρ",
			"class<brave-browser>": "ΏθοΒ",
			"class<tor-browser>": "ΎΞ▒",
			"class<firefox-developer-edition>": "ΏθοΛ",
			"class<kitty|konsole>": "ΌψΗ",
			"class<kitty-dropterm>": "ΎΕι",
			"class<com.mitchellh.ghostty>": "ΌηΧ",
			"class<org.wezfurlong.wezterm>": "ΌςΖ",
			"class<org.omarchy.terminal>": "≤░ΠΨ",
			"class<[Tt]hunderbird|[Tt]hunderbird-esr>": "ΎΞ░",
			"class<eu.betterbird.Betterbird>": "ΎΞ░",
			"title<.*gmail.*>": "≤░Λτ",
			"class<[Tt]elegram-desktop|org.telegram.desktop|io.github.tdesktop_x64.TDesktop>": "ΌΙΩ",
			"class<discord|[Ww]ebcord|Vesktop>": "ΎΘ┐",
			"title<.*whatsapp.*>": "ΎΙ▓",
			"title<.*zapzap.*>": "ΎΙ▓",
			"title<.*messenger.*>": "ΎΚθ",
			"title<.*facebook.*>": "ΎΓγ ",
			"title<.*reddit.*>": "ΎΛΒ",
			"title<.*ChatGPT.*>": "≤░γσ",
			"class<.*ChatGPT.*>": "≤░γσ",
			"title<.*deepseek.*>": "≤░γσ",
			"title<.*qwen.*>": "≤░γσ",
			"class<subl>": "≤░Ζ│",
			"class<slack>": "ΎΗα",
			"class<mpv>": "ΎΞχ",
			"class<celluloid|Zoom>": "ΎΑ╜",
			"class<Cider>": "≤░ΟΗ ",
			"title<.*Picture-in-Picture.*>": "ΎΦυ",
			"title<.*youtube.*>": "ΎΖς",
			"class<vlc>": "≤░Χ╝",
			"title<.*cmus.*>": "ΎΑΒ",
			"class<[Ss]potify>": "ΎΗ╝",
			"class<virt-macodeger>": "Όφ╗",
			"class<.virt-manager-wrapped>": "Όφ╗",
			"class<virtualbox manager>": "ΏθΤ╜",
			"title<virtualbox>": "ΏθΤ╜",
			"class<remmina>": "ΏθΨξΎ╕Π",
			"class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "≤░ρη",
			"class<dev.zed.Zed>": "≤░╡Β",
			"class<codeblocks>": "≤░Ζσ",
			"title<.*github.*>": "ΎΕΥ",
			"class<mousepad>": "ΎΖε",
			"class<libreoffice-writer>": "Όγξ",
			"class<libreoffice-startcenter>": " ≤░ΠΗ",
			"class<libreoffice-calc>": "ΎΞ╗",
			"title<.*nvim ~.*>": "ΎΞψ",
			"class<org.gnome.Nautilus>": "≤░μΗ",
			"title<.*vim.*>": "ΌθΖ",
			"title<.*figma.*>": "Ό╜Θ",
			"title<.*jira.*>": "Όζε",
			"class<jetbrains-idea>": "Όη╡",
			"title<*.VSCode.*>": "≤░ρη",
			"class<.*code.*>": "≤░ρη",
			"class<obs|com.obsproject.Studio>": "Όχπ",
			"class<polkit-gnome-authentication-agent-1>": "≤░ΤΔ",
			"class<nwg-look>": "ΌφΤ",
			"class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "≤▒κτ",
			"class<steam>": "ΎΗ╢",
			"class<thunar|nemo>": "≤░ζ░",
			"class<Gparted>": "ΎΔΘ",
			"class<gimp>": "ΎΝ╕",
			"class<emulator>": "ΏθΥ▒",
			"class<android-studio>": "ΎΖ╗",
			"class<org.pipewire.Helvum>": "≤░ΥΔ",
			"class<localsend>": "ΎΘι",
			"class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "≤░╣δ"
		}
	},
	"custom/omarchy": {
		"format": "<span font='omarchy'>\ue900</span>",
		"on-click": "omarchy-menu",
		"on-click-right": "xdg-terminal-exec",
		"tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
	},
	"custom/voxtype": {
		"exec": "omarchy-voxtype-status",
		"return-type": "json",
		"format": "{icon}",
		"format-icons": {
			"idle": "",
			"recording": "≤░Ξυ",
			"transcribing": "≤░Φθ"
		},
		"tooltip": true,
		"on-click-right": "omarchy-voxtype-config",
		"on-click": "omarchy-voxtype-model"
	},
	"custom/idle-indicator": {
		"on-click": "omarchy-toggle-idle",
		"exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
		"signal": 9,
		"return-type": "json"
	},
	"custom/notification-silencing-indicator": {
		"on-click": "omarchy-toggle-notification-silencing",
		"exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
		"signal": 10,
		"return-type": "json"
	},
	"custom/update": {
		"format": "ΎΑκ",
		"exec": "omarchy-update-available",
		"on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
		"tooltip-format": "Omarchy update available",
		"signal": 7,
		"interval": 21600
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "≤░δΛ",
			"deactivated": "≤░╛ς"
		}
	},
	"cpu": {
		"interval": 2,
		"format": "≤░Ξδ {usage}%",
		"on-click": "omarchy-launch-or-focus-tui btop"
	},
	"memory": {
		"interval": 2,
		"format": "ΌΚο {percentage}%",
		"on-click": "omarchy-launch-or-focus-tui btop"
	},
	"backlight": {
		"device": "intel_backlight",
		"format": "{icon}",
		"tooltip-format": "{percent}%",
		"format-icons": [
			"ΏθΝΣ",
			"ΏθΝα",
			"ΏθΝΩ",
			"ΏθΝΨ",
			"ΏθΝΧ"
		]
	},
	"clock": {
		"format": "ΎΑΩ {:%H:%M %d/%m/%Y}",
		"format-alt": "{:L%d %B W%V %Y}",
		"tooltip-format": "<span>{calendar}</span>",
		"calendar": {
			"mode": "month",
			"mode-mon-col": 3,
			"on-click-right": "mode",
			"format": {
				"month": "<span color='#ffead3'><b>{}</b></span>",
				"weekdays": "<span color='#ffcc66'><b>{}</b></span>",
				"today": "<span color='#ff6699'><b>{}</b></span>"
			},
		},
		"on-click-right": "omarchy-launch-floating-terminal-with-presentation omarchy-tz-select"
	},
	"network": {
		"format-icons": [
			"≤░νψ",
			"≤░νθ",
			"≤░νλ",
			"≤░νξ",
			"≤░νρ"
		],
		"format": "{icon}",
		"format-wifi": "{icon}",
		"format-ethernet": "≤░ΙΑ",
		"format-disconnected": "≤░νχ",
		"tooltip-format-wifi": "{essid} ({frequency} GHz)\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
		"tooltip-format-ethernet": "έΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
		"tooltip-format-disconnected": "Disconnected",
		"interval": 3,
		"spacing": 1,
		"on-click": "omarchy-launch-wifi"
	},
	"battery": {
		"format": "{capacity}% {icon}",
		"format-discharging": "{capacity}% {icon}",
		"format-charging": "{capacity}% {icon}",
		"format-plugged": "ΎΘο",
		"format-icons": {
			"charging": [
				"≤░λε",
				"≤░ΓΗ",
				"≤░ΓΘ",
				"≤░ΓΙ",
				"≤░λζ",
				"≤░ΓΚ",
				"≤░λη",
				"≤░ΓΛ",
				"≤░ΓΜ",
				"≤░ΓΖ"
			],
			"default": [
				"≤░Β║",
				"≤░Β╗",
				"≤░Β╝",
				"≤░Β╜",
				"≤░Β╛",
				"≤░Β┐",
				"≤░ΓΑ",
				"≤░ΓΒ",
				"≤░ΓΓ",
				"≤░Β╣"
			]
		},
		"format-full": "≤░ΓΖ {capacity}%",
		"tooltip-format-discharging": "{timeTo}",
		"tooltip-format-charging": "{timeTo}",
		"interval": 5,
		"on-click": "omarchy-menu power",
		"states": {
			"warning": 20,
			"critical": 10
		}
	},
	"bluetooth": {
		"format": "ΎΛΦ",
		"format-disabled": "≤░Γ▓",
		"format-connected": "≤░Γ▒",
		"tooltip-format": "Devices connected: {num_connections}",
		"on-click": "omarchy-launch-bluetooth"
	},
	"pulseaudio#input": {
		"format-source": "ΎΕ░",
		"format-source-muted": "ΎΕ▒ ",
		"format": "{format_source}",
		"tooltip-format": "{format_source} {source_volume}%",
		"scroll-step": 1,
		"smooth-scrolling-threshold": 1,
		"max-volume": 100,
		"on-click": "omarchy-launch-or-focus-tui wiremix",
		"on-click-right": "pamixer -t",
		"on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +1%",
		"on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -1%"
	},
	"pulseaudio#output": {
		"format": "{icon}",
		"tooltip-format": "{icon}  {volume}%",
		"format-muted": "ΎΑο off",
		"format-icons": {
			"default": [
				"ΎΑξ"
			]
		},
		"max-volume": 100,
		"scroll-step": 2,
		"smooth-scrolling-threshold": 1,
		"on-click": "omarchy-launch-or-focus-tui wiremix",
		"on-click-right": "pamixer -t"
	},
	"power-profiles-daemon": {
		"format": "{icon}",
		"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
		"tooltip": true,
		"format-icons": {
			"default": "≤░ΥΖ",
			"performance": "≤░ΥΖ",
			"balanced": "≤░╛Ζ",
			"power-saver": "≤░╛Η"
		}
	},
	"mpris": {
		"format": "≤░ΜΟ {artist}-{title}",
		"format-paused": "<i><span color='grey'>{status_icon} {artist}</span></i>",
		"max-length": 30,
		"player-icons": {
			"default": "έΠ╕",
			"mpv": "ΏθΟ╡"
		},
		"status-icons": {
			"paused": "≤░ΜΡ"
		},
		"ignored-players": [
			"firefox",
			"chromium",
			"brave"
		]
	},
	"custom/updatespacman": {
		"format": "{}{icon}",
		"return-type": "json",
		"format-icons": {
			"has-updates": " ≤░ΠΨ",
			"updated": ""
		},
		"exec-if": "which waybar-module-pacman-updates",
		"exec": "waybar-module-pacman-updates --no-zero-output"
	},
	"custom/screenrecording-indicator": {
		"on-click": "omarchy-cmd-screenrecord",
		"exec": "$OMARCHY_PATH/default/waybar/indicators/screen-recording.sh",
		"signal": 8,
		"return-type": "json"
	},
	"tray": {
		"icon-size": 11,
		"spacing": 5,
		"show-passive-items": true
	},
}
